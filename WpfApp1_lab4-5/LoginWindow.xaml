<Window x:Class="WpfApp1_lab4_5.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Гостиничный комплекс"
        Height="480" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFCFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <!-- форма слева -->
            <ColumnDefinition Width="*"/>
            <!-- фото справа -->
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ — форма входа -->
        <Grid Grid.Column="0" Margin="48,32,48,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Вверху: "Нет аккаунта? Зарегистрироваться" -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <TextBlock Text="Нет аккаунта?"
                           VerticalAlignment="Center"
                           Foreground="#1A1A1A"
                           FontSize="13"
                           Margin="0,0,8,0"/>
                <Border BorderBrush="#1A1A1A" BorderThickness="1"
                        CornerRadius="4" Padding="12,4">
                    <TextBlock Text="Регистрация"
                               Foreground="#1A1A1A"
                               FontSize="13"
                               Cursor="Hand"
                               MouseLeftButtonUp="SwitchToRegister"/>
                </Border>
            </StackPanel>

            <!-- Форма по центру -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <TextBlock Text="ВОЙТИ"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#1A1A1A"
                           Margin="0,0,0,26"/>

                <!-- Логин -->
                <TextBlock 
                      Text="Email"
                            Margin="0,0,0,5"
                            FontWeight="Medium"/>
                <Border BorderBrush="#CCCCCC" BorderThickness="1"
                        Height="44" Margin="0,0,0,12">
                    <TextBox x:Name="TxtLogin"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Padding="12,0"
                             FontSize="14"
                             Foreground="#1A1A1A"/>
                </Border>

                <!-- Пароль -->
                <TextBlock 
                    Text="Пароль"
                        Margin="0,0,0,5"
                        FontSize="12"
                        FontWeight="Medium"/>
                <Border BorderBrush="#CCCCCC" BorderThickness="1"
                        Height="44" Margin="0,0,0,24">
                    <PasswordBox x:Name="TxtPassword"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"
                                 FontSize="14"
                                 Foreground="#1A1A1A"/>
                </Border>

                <!-- Ошибка -->
                <TextBlock x:Name="TxtError"
                           Foreground="Red"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Кнопка -->
                <Button x:Name="BtnLogin"
                        Content="Войти"
                        Height="44"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#FFFCFC"
                        BorderThickness="0"
                        Click="BtnAction_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6F4E37"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5a3e2b"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Grid>

        <!-- ПРАВАЯ ЧАСТЬ — фото -->
        <Border Grid.Column="1" ClipToBounds="True">
            <Image Source="Assets/hotel.jpg"
                   Stretch="UniformToFill"/>
        </Border>

    </Grid>
</Window>