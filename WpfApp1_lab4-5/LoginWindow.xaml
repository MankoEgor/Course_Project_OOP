<Window x:Class="WpfApp1_lab4_5.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Height="480" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ФОРМА -->
        <Grid Grid.Column="0"
              Background="{DynamicResource BrushPanelBackground}"
              Margin="48,32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верх -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource NoAccount}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Border BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        Padding="12,4">
                    <TextBlock Text="{DynamicResource RegisterButton}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Cursor="Hand"
                               MouseLeftButtonUp="SwitchToRegister"/>
                </Border>
            </StackPanel>

            <!-- Центр -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <TextBlock Text="{DynamicResource LoginTitleBig}"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,26"/>

                <!-- Email -->
                <TextBlock Text="{DynamicResource Email}"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="TxtLogin"
                         Height="40"
                         Margin="0,0,0,12"
                         Padding="10"/>

                <!-- Password -->
                <TextBlock Text="{DynamicResource Password}"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="TxtPassword"
                             Height="40"
                             Margin="0,0,0,20"
                             Padding="10"/>

                <!-- Ошибка -->
                <TextBlock x:Name="TxtError"
                           Foreground="{DynamicResource BrushDanger}"
                           Margin="0,0,0,10"/>

                <!-- Кнопка -->
                <Button Content="{DynamicResource LoginButton}"
                        Height="42"
                        Click="BtnAction_Click"/>
            </StackPanel>
        </Grid>

        <!-- КАРТИНКА -->
        <Border Grid.Column="1">
            <Image Source="Assets/hotel.jpg"
                   Stretch="UniformToFill"/>
        </Border>

    </Grid>
</Window>