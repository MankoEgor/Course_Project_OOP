<Window x:Class="WpfApp1_lab4_5.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Height="480" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushWindowBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource BrushPanelBackground}"
                Padding="48,32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource NoAccount}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <Button Content="{DynamicResource RegisterButton}"
                            Height="30"
                            Padding="14,0"
                            Click="SwitchToRegister"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">

                    <TextBlock Text="{DynamicResource LoginTitleBig}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontSize="26"
                               FontWeight="Bold"
                               Margin="0,0,0,26"/>

                    <TextBlock Text="{DynamicResource Email}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="0,0,0,5"/>

                    <TextBox x:Name="TxtLogin"
                             Height="42"
                             Margin="0,0,0,12"
                             Padding="12,0"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="{DynamicResource Password}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="TxtPassword"
                                 Height="42"
                                 Margin="0,0,0,24"
                                 Padding="12,0"/>

                    <TextBlock x:Name="TxtError"
                               Foreground="{DynamicResource BrushDanger}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <Button Content="{DynamicResource LoginButton}"
                            Height="44"
                            Click="BtnAction_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1">
            <Image Source="Assets/hotel.jpg" Stretch="UniformToFill"/>
        </Border>
    </Grid>
</Window>