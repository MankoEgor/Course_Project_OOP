<Window x:Class="WpfApp1_lab4_5.RegWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AppTitle}"
        Height="500" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="500"/>
        </Grid.ColumnDefinitions>

        <!-- ФОТО -->
        <Border Grid.Column="0">
            <Image Source="/Assets/hotel.jpg"
                   Stretch="UniformToFill"/>
        </Border>

        <!-- ФОРМА -->
        <Grid Grid.Column="1"
              Background="{DynamicResource BrushPanelBackground}"
              Margin="40,30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верх -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <TextBlock Text="{DynamicResource HaveAccount}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Button Content="{DynamicResource LoginButton}"
                        Height="28"
                        Padding="14,0"
                        Click="BtnSwitch_Click"/>
            </StackPanel>

            <!-- Центр -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <TextBlock Text="{DynamicResource RegisterTitleBig}"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,24"/>

                <!-- Full Name -->
                <TextBlock Text="{DynamicResource FullName}"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="TxtFullName"
                         Height="40"
                         Margin="0,0,0,12"
                         Padding="10"/>

                <!-- Email -->
                <TextBlock Text="{DynamicResource Email}"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="TxtLogin"
                         Height="40"
                         Margin="0,0,0,12"
                         Padding="10"/>

                <!-- Password -->
                <TextBlock Text="{DynamicResource Password}"
                           Margin="0,0,0,5"/>

                <PasswordBox x:Name="TxtPassword"
                             Height="40"
                             Margin="0,0,0,10"
                             Padding="10"/>

                <!-- Error -->
                <TextBlock x:Name="TxtError"
                           Foreground="{DynamicResource BrushDanger}"
                           Margin="0,0,0,10"/>

                <!-- Button -->
                <Button Content="{DynamicResource RegisterButton}"
                        Height="42"
                        Click="BtnAction_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>