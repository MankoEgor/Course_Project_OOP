<Window x:Class="WpfApp1_lab4_5.RegWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Гостиничный комплекс"
        Height="500" Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFCFC">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <!-- фото -->
            <ColumnDefinition Width="500"/>
            <!-- форма -->
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ЧАСТЬ — фото отеля -->
        <Border Grid.Column="0" CornerRadius="12,0,0,12" ClipToBounds="True">
            <Image x:Name="HotelImage"
                   Source="/Assets/hotel.jpg"
                   Stretch="UniformToFill"/>
        </Border>

        <!-- ПРАВАЯ ЧАСТЬ — форма -->
        <Grid Grid.Column="1" Margin="40,30,40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- верхняя строка с Sign In -->
                <RowDefinition Height="*"/>
                <!-- форма по центру -->
            </Grid.RowDefinitions>

            <!-- Вверху справа: "Уже есть аккаунт?" -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock x:Name="TxtHaveAccount"
                           Text="Уже есть аккаунт?"
                           VerticalAlignment="Center"
                           Foreground="#1A1A1A"
                           Margin="0,0,8,0"/>
                <Button x:Name="BtnSwitch"
                        Content="Войти"
                        Height="28" Padding="14,0"
                        Background="Transparent"
                        Foreground="#6F4E37"
                        FontWeight="SemiBold"
                        BorderBrush="#6F4E37"
                        BorderThickness="1"
                        Click="BtnSwitch_Click"/>
            </StackPanel>

            <!-- Форма по центру -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">

                <!-- Заголовок -->
                <TextBlock x:Name="TxtFormTitle"
                           Text="СОЗДАТЬ АККАУНТ"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1A1A1A"
                           Margin="0,0,0,24"/>

                <!-- Поле: Полное имя (только регистрация) -->
                <TextBlock Text="Полное имя"
                            Foreground="#1a1a1a"
                            Margin="5,0,0,5"
                            FontWeight="Medium"/>
                <Border x:Name="FieldFullName"
                        BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Padding="12,0"
                        Height="44" Margin="0,0,0,12">
                    <TextBox x:Name="TxtFullName"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Foreground="#1A1A1A" FontSize="16">
                        <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                    </TextBox>
                </Border>

                <!-- Поле: Логин -->
                <TextBlock Text="Email"
                            Foreground="#1a1a1a"
                            Margin="5,0,0,5"
                            FontWeight="Medium"/>
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Padding="12,0"
                        Height="44" Margin="0,0,0,12">
                    <TextBox x:Name="TxtLogin"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Foreground="#1A1A1A">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <TextBlock Text="Пароль"
                            Foreground="#1a1a1a"
                            Margin="5,0,0,5"
                            FontWeight="Medium"/>

                <!-- Поле: Пароль -->
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Padding="12,0"
                        Height="44" Margin="0,0,0,8">
                    <PasswordBox x:Name="TxtPassword"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Foreground="#1A1A1A"/>
                </Border>

                <!-- Ошибка -->
                <TextBlock x:Name="TxtError"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>

                <!-- Кнопка действия -->
                <Button x:Name="BtnAction"
                        Content="Зарегистрироваться"
                        Height="44"
                        Background="#6F4E37"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="BtnAction_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Grid>
    </Grid>
</Window>