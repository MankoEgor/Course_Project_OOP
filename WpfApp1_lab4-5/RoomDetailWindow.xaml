<Window x:Class="WpfApp1_lab4_5.RoomDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource RoomDetailsWindow}"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushWindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="280"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BrushBadgeBackground}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🏨" FontSize="80" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource RoomPhotoPlaceholder}"
                           Foreground="{DynamicResource BrushTextMuted}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="16"
                Background="{DynamicResource BrushPrimary}"
                CornerRadius="6"
                Padding="10,4">
            <TextBlock x:Name="TxtCategory"
                       Foreground="{DynamicResource BrushTextOnDark}"
                       FontSize="13"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TxtFullName"
                               Grid.Column="0"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               TextWrapping="Wrap"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="★"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="18"/>
                        <TextBlock x:Name="TxtRating"
                                   Foreground="{DynamicResource BrushAccent}"
                                   FontSize="18"
                                   Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>

                <WrapPanel Margin="0,0,0,14">
                    <Border Background="{DynamicResource BrushBadgeBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,4"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource RoomFloorLabel}"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="13"/>
                            <TextBlock x:Name="TxtFloor"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BrushBadgeBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,4"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource RoomAreaLabel}"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="13"/>
                            <TextBlock x:Name="TxtArea"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource BrushBadgeBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,4"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource RoomGuestsLabel}"
                                       Foreground="{DynamicResource BrushTextSecondary}"
                                       FontSize="13"/>
                            <TextBlock x:Name="TxtCapacity"
                                       Foreground="{DynamicResource BrushTextPrimary}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="BadgeAvailable"
                            CornerRadius="6"
                            Padding="10,4"
                            Margin="0,0,8,8">
                        <TextBlock x:Name="TxtAvailable" FontSize="13"/>
                    </Border>
                </WrapPanel>

                <TextBlock Text="{DynamicResource RoomDescription}"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>

                <TextBlock x:Name="TxtDescription"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           LineHeight="22"
                           Margin="0,0,0,16"/>

                <TextBlock Text="{DynamicResource RoomAmenities}"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,8"/>

                <WrapPanel x:Name="AmenitiesPanel" Margin="0,0,0,8"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="TxtPrice"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushPrimary}"/>
                    <TextBlock Text="{DynamicResource RoomPriceSuffix}"
                               FontSize="14"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               VerticalAlignment="Bottom"
                               Margin="4,0,0,4"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <Button x:Name="BtnEdit"
                            Content="{DynamicResource EditButton}"
                            Height="38"
                            Width="140"
                            Margin="0,0,10,0"
                            Background="{DynamicResource BrushSuccess}"
                            Visibility="Collapsed"
                            Click="BtnEdit_Click"/>

                    <Button x:Name="BtnDelete"
                            Content="{DynamicResource DeleteButton}"
                            Height="38"
                            Width="100"
                            Margin="0,0,10,0"
                            Background="{DynamicResource BrushDanger}"
                            Visibility="Collapsed"
                            Click="BtnDelete_Click"/>

                    <Button x:Name="BtnBook"
                            Content="{DynamicResource BookButton}"
                            Height="38"
                            Width="150"
                            Background="{DynamicResource BrushPrimary}"
                            Click="BtnBook_Click"/>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>