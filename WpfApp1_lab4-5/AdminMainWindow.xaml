<Window x:Class="WpfApp1_lab4_5.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:WpfApp1_lab4_5.UserControls"
        mc:Ignorable="d"
        Title="{DynamicResource AdminPanel}"
        Height="720"
        Width="1240"
        MinHeight="620"
        MinWidth="1020"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushBackground}">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#F8F3ED"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BrushAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource AnimatedCardStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushPanel}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>

        <Style x:Key="SmallLangButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundedButtonStyle}">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource BrushPrimary}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,6,0,24">
                    <TextBlock Text="{DynamicResource AppTitle}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="TxtAdminName"
                               Text="Администратор"
                               FontSize="14"
                               Foreground="#EADFD3"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard"
                            Content="{DynamicResource Dashboard}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnDashboard_Click"/>

                    <Button x:Name="BtnRooms"
                            Content="{DynamicResource RoomsManagement}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnRooms_Click"/>

                    <Button x:Name="BtnUsers"
                            Content="{DynamicResource Users}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnUsers_Click"/>

                    <Button x:Name="BtnBookings"
                            Content="{DynamicResource Bookings}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnBookings_Click"/>

                    <Button x:Name="BtnProfile"
                            Content="{DynamicResource Profile}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnProfile_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="{DynamicResource OpenClientView}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnOpenClientView_Click"/>

                    <Button Content="{DynamicResource Logout}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BrushPanel}"
                    CornerRadius="18"
                    Padding="22"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="TxtPageTitle"
                                   Text="{DynamicResource Dashboard}"
                                   
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushLogText}"/>
                        <TextBlock x:Name="TxtPageSubtitle"
                                   Text="{DynamicResource PageSubtitleDashboard}"
                                   FontSize="14"
                                   Foreground="{DynamicResource BrushSubText}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="{DynamicResource LanguageRu}"
                                Style="{StaticResource SmallLangButtonStyle}"
                                Click="BtnRu_Click"/>

                        <Button Content="{DynamicResource LanguageEn}"
                                Style="{StaticResource SmallLangButtonStyle}"
                                Margin="0,0,12,0"
                                Click="BtnEn_Click"/>

                        <Border Background="{DynamicResource BrushBackground}"
                                CornerRadius="12"
                                Padding="14,8"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="TxtCurrentDate"
                                       Foreground="{DynamicResource BrushPrimary}"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Workspace -->
            <Grid Grid.Row="1">

                <!-- Dashboard -->
                <ScrollViewer x:Name="DashboardView" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,4">
                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource TotalRooms}" FontSize="14" Foreground="{DynamicResource BrushSubText}"/>
                                    <TextBlock x:Name="TxtTotalRooms"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushLogText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource AvailableRooms}" FontSize="14" Foreground="{DynamicResource BrushSubText}"/>
                                    <TextBlock x:Name="TxtAvailableRooms"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushSuccess}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource BusyRooms}" FontSize="14" Foreground="{DynamicResource BrushSubText}"/>
                                    <TextBlock x:Name="TxtBusyRooms"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushDanger}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource AveragePrice}" FontSize="14" Foreground="{DynamicResource BrushSubText}"/>
                                    <TextBlock x:Name="TxtAveragePrice"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushPrimary}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Background="{DynamicResource BrushPanel}"
                                CornerRadius="16"
                                Padding="22">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource QuickActions}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushLogText}"
                                           Margin="0,0,0,14"/>

                                <WrapPanel>
                                    <Button Content="{DynamicResource AddRoom}"
                                            Background="{DynamicResource BrushSuccess}"
                                            Style="{StaticResource ActionButtonStyle}"
                                             Command="{Binding AddRoomCommand}"/>

                                    <Button Content="{DynamicResource OpenRoomsList}"
                                            Background="{DynamicResource BrushPrimary}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="BtnRooms_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Rooms -->
                <Grid x:Name="RoomsView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BrushPanel}"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchRoomBox"
                                     Height="36"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     ToolTip="{DynamicResource SearchTooltip}"
                                     Foreground="{DynamicResource BrushLogText}"
                                     TextChanged="SearchRoomBox_TextChanged"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="{DynamicResource Add}"
                                        Background="{DynamicResource BrushSuccess}"
                                        Style="{StaticResource ActionButtonStyle}"
                                         Command="{Binding AddRoomCommand}"/>

                                <Button Content="{DynamicResource Edit}"
                                        Background="{DynamicResource BrushPrimary}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="BtnEdit_Click"/>

                                <Button Content="{DynamicResource Delete}"
                                        Background="{DynamicResource BrushDanger}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DeleteRoomCommand}"/>

                                <Button Content="{DynamicResource Refresh}"
                                        Background="{DynamicResource BrushAccent}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding RefreshRoomsCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="RoomsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="{DynamicResource BrushPanel}"
                              AlternatingRowBackground="{DynamicResource BrushBackground}"
                              BorderBrush="#DDD"
                              BorderThickness="1"
                              FontSize="14">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Id}" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="{DynamicResource ShortName}" Binding="{Binding ShortName}" Width="170"/>
                            <DataGridTextColumn Header="{DynamicResource FullName}" Binding="{Binding FullName}" Width="220"/>
                            <DataGridTextColumn Header="{DynamicResource Category}" Binding="{Binding Category}" Width="140"/>
                            <DataGridTextColumn Header="{DynamicResource Price}" Binding="{Binding PricePerNight}" Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource Floor}" Binding="{Binding Floor}" Width="80"/>
                            <DataGridTextColumn Header="{DynamicResource Area}" Binding="{Binding Area}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource Capacity}" Binding="{Binding Capacity}" Width="110"/>
                            <DataGridCheckBoxColumn Header="{DynamicResource Available}" Binding="{Binding IsAvailable}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Rating}" Binding="{Binding Rating}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Users -->
                <Border x:Name="UsersView"
                        Visibility="Collapsed"
                        Background="{DynamicResource BrushPanel}"
                        CornerRadius="16"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Users}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushLogText}"/>
                        <TextBlock Text="{DynamicResource UsersStub}"
                                   Foreground="{DynamicResource BrushSubText}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Bookings -->
                <Border x:Name="BookingsView"
                        Visibility="Collapsed"
                        Background="{DynamicResource BrushPanel}"
                        CornerRadius="16"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Bookings}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushLogText}"/>
                        <TextBlock Text="{DynamicResource BookingsStub}"
                                   Foreground="{DynamicResource BrushSubText}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ProfileView"
        Visibility="Collapsed"
        Background="{DynamicResource BrushPanel}"
        CornerRadius="16"
        Padding="24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Левая часть -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource ProfileTitle}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushLogText}"
                                           Margin="0,0,0,20"/>

                                <TextBlock 
                                    Text="{DynamicResource ProfileName}" 
                                    Foreground="{DynamicResource BrushLogText}"
                                    Margin="0,0,0,6"/>
                                <Border Background="#F8F8F8" CornerRadius="8" Padding="10" Margin="0,0,0,14">
                                    <TextBox x:Name="TxtProfileFullName"
                             BorderThickness="0"
                             Background="Transparent"/>
                                </Border>

                                <TextBlock 
                                    Text="{DynamicResource ProfileEmail}" 
                                    Foreground="{DynamicResource BrushLogText}"
                                    Margin="0,0,0,6"/>
                                <Border Background="#F8F8F8" CornerRadius="8" Padding="10" Margin="0,0,0,14">
                                    <TextBox x:Name="TxtProfileEmail"
                                               BorderThickness="0"
                                               Background="Transparent"
                                               IsReadOnly="True"/> 
                                </Border>

                                <TextBlock 
                                    Text="{DynamicResource ProfileRole}" 
                                    Foreground="{DynamicResource BrushLogText}"
                                    Margin="0,0,0,6"/>
                                <Border 
                                    Background="#F8F8F8" 
                                    CornerRadius="8" Padding="10" 
                                    Margin="0,0,0,18">
                                    <TextBlock x:Name="TxtProfileRole"/>
                                </Border>

                                <Button Content="{DynamicResource ProfileSave}"
                                        Width="180"
                                        Height="38"
                                        Background="{DynamicResource BrushPrimary}"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="BtnSaveProfile_Click"/>
                            </StackPanel>

                            <!-- Правая часть -->
                            <Border Grid.Column="2"
                                    Background="#F8F8F8"
                                    CornerRadius="14"
                                    Padding="18">   
                                <StackPanel>
                                    <TextBlock 
                                        Text="{DynamicResource InterfaceSettings}"
                                        FontSize="20"
                                        FontWeight="Bold"
                                        Margin="0,0,0,18"/>  

                                    <TextBlock 
                                        Text="{DynamicResource LanguageLabel}" 
                                        Margin="0,0,0,8"/>
                                    <StackPanel 
                                        Orientation="Horizontal" 
                                        Margin="0,0,0,18">
                                        <Button Content="{DynamicResource LanguageRu}"
                                                Width="70"
                                                Height="34"
                                                Margin="0,0,10,0"
                                                Click="BtnRu_Click"/>
                                        <Button Content="{DynamicResource LanguageEn}"
                                                Width="70"
                                                Height="34"
                                                Click="BtnEn_Click"/>
                                    </StackPanel>

                                    <TextBlock 
                                        Text="{DynamicResource ThemeLabel}" 
                                        Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{DynamicResource LightTheme}"
                                                Width="140"
                                                Height="34"
                                                Margin="0,0,10,0"
                                                Click="BtnLightTheme_Click"/>
                                        <Button Content="{DynamicResource DarkTheme}"
                                                Width="140"
                                                Height="34"
                                                Click="BtnDarkTheme_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>