<Window x:Class="WpfApp1_lab4_5.AdminMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:uc="clr-namespace:WpfApp1_lab4_5.UserControls"
        mc:Ignorable="d"
        Title="{DynamicResource AdminPanel}"
        Height="720"
        Width="1240"
        MinHeight="620"
        MinWidth="1020"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BrushWindowBackground}">

    <Window.Resources>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextOnDark}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root"
                                        Property="Background"
                                        Value="{DynamicResource BrushAccent}"/>
                            </MultiTrigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle"
       TargetType="Button"
       BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextOnDark}"/>
        </Style>

        <Style x:Key="MetricCardStyle"
               TargetType="Border"
               BasedOn="{StaticResource FadeInCardStyle}">
            <Setter Property="Background" Value="{DynamicResource BrushCardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>

        <Style x:Key="SmallLangButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource BrushPrimary}"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextOnDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BrushSidebarBackground}">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,6,0,24">
                    <TextBlock Text="{DynamicResource AppTitle}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextOnDark}"/>

                    <TextBlock x:Name="TxtAdminName"
                               Text="Администратор"
                               FontSize="14"
                               Foreground="{DynamicResource BrushTextOnDark}"
                               Opacity="0.8"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="BtnDashboard"
                            Content="{DynamicResource Dashboard}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnDashboard_Click"/>

                    <Button x:Name="BtnRooms"
                            Content="{DynamicResource RoomsManagement}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnRooms_Click"/>

                    <Button x:Name="BtnUsers"
                            Content="{DynamicResource Users}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnUsers_Click"/>

                    <Button x:Name="BtnBookings"
                            Content="{DynamicResource Bookings}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnBookings_Click"/>

                    <Button x:Name="BtnProfile"
                            Content="{DynamicResource Profile}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnProfile_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="{DynamicResource OpenClientView}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnOpenClientView_Click"/>

                    <Button Content="{DynamicResource Logout}"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource BrushPanelBackground}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="TxtPageTitle"
                                   Text="{DynamicResource Dashboard}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>

                        <TextBlock x:Name="TxtPageSubtitle"
                                   Text="{DynamicResource PageSubtitleDashboard}"
                                   FontSize="14"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="{DynamicResource LanguageRu}"
                                Style="{StaticResource SmallLangButtonStyle}"
                                Click="BtnRu_Click"/>

                        <Button Content="{DynamicResource LanguageEn}"
                                Style="{StaticResource SmallLangButtonStyle}"
                                Margin="0,0,12,0"
                                Click="BtnEn_Click"/>

                        <Border Background="{DynamicResource BrushBadgeBackground}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14,8"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="TxtCurrentDate"
                                       Foreground="{DynamicResource BrushPrimary}"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">

                <ScrollViewer x:Name="DashboardView" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <WrapPanel Margin="0,0,0,4">
                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource TotalRooms}"
                                               FontSize="14"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock x:Name="TxtTotalRooms"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource AvailableRooms}"
                                               FontSize="14"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock x:Name="TxtAvailableRooms"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushSuccess}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource BusyRooms}"
                                               FontSize="14"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock x:Name="TxtBusyRooms"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushDanger}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource MetricCardStyle}" Width="220">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource AveragePrice}"
                                               FontSize="14"
                                               Foreground="{DynamicResource BrushTextSecondary}"/>
                                    <TextBlock x:Name="TxtAveragePrice"
                                               FontSize="32"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushPrimary}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Border Background="{DynamicResource BrushPanelBackground}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="22">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource QuickActions}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           Margin="0,0,0,14"/>

                                <WrapPanel>
                                    <Button Content="{DynamicResource AddRoom}"
                                            Background="{DynamicResource BrushSuccess}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Command="{Binding AddRoomCommand}"/>

                                    <Button Content="{DynamicResource OpenRoomsList}"
                                            Background="{DynamicResource BrushPrimary}"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="BtnRooms_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid x:Name="RoomsView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource BrushPanelBackground}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="SearchRoomBox"
                                     Height="36"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     ToolTip="{DynamicResource SearchTooltip}"
                                     TextChanged="SearchRoomBox_TextChanged"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="{DynamicResource Add}"
                                        Background="{DynamicResource BrushSuccess}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding AddRoomCommand}"/>

                                <Button Content="{DynamicResource Edit}"
                                        Background="{DynamicResource BrushPrimary}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="BtnEdit_Click"/>

                                <Button Content="{DynamicResource Delete}"
                                        Background="{DynamicResource BrushDanger}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding DeleteRoomCommand}"/>

                                <Button Content="{DynamicResource Refresh}"
                                        Background="{DynamicResource BrushAccent}"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Command="{Binding RefreshRoomsCommand}"/>

                                <Button Style="{StaticResource IconButtonStyle}"
                                    Width="44"
                                    Height="36"
                                    MinWidth="44"
                                    Margin="0,0,10,0"
                                    ToolTip="Undo"
                                    Command="{Binding UndoCommand}">
                                    <Image Source="/Assets/undo_24dp_FFFFFF.png"
                                       Width="20"
                                       Height="20"/>
                                </Button>

                                <!-- Redo -->
                                <Button Style="{StaticResource IconButtonStyle}"
                                    Width="44"
                                    Height="36"
                                    MinWidth="44"
                                    Margin="0"
                                    ToolTip="Redo"
                                    Command="{Binding RedoCommand}">
                                    <Image Source="/Assets/redo_24dp_FFFFFF.png"
                                       Width="20"
                                       Height="20"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="RoomsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="{DynamicResource BrushPanelBackground}"
                              AlternatingRowBackground="{DynamicResource BrushWindowBackground}"
                              BorderBrush="{DynamicResource BrushBorder}"
                              BorderThickness="1"
                              FontSize="14"
                              SelectionChanged="RoomsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource Id}" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="{DynamicResource ShortName}" Binding="{Binding ShortName}" Width="170"/>
                            <DataGridTextColumn Header="{DynamicResource FullName}" Binding="{Binding FullName}" Width="220"/>
                            <DataGridTextColumn Header="{DynamicResource Category}" Binding="{Binding Category}" Width="140"/>
                            <DataGridTextColumn Header="{DynamicResource Price}" Binding="{Binding PricePerNight}" Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource Floor}" Binding="{Binding Floor}" Width="80"/>
                            <DataGridTextColumn Header="{DynamicResource Area}" Binding="{Binding Area}" Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource Capacity}" Binding="{Binding Capacity}" Width="110"/>
                            <DataGridCheckBoxColumn Header="{DynamicResource Available}" Binding="{Binding IsAvailable}" Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource Rating}" Binding="{Binding Rating}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Border x:Name="UsersView"
                        Visibility="Collapsed"
                        Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Users}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="{DynamicResource UsersStub}"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border x:Name="BookingsView"
                        Visibility="Collapsed"
                        Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Bookings}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushTextPrimary}"/>
                        <TextBlock Text="{DynamicResource BookingsStub}"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border x:Name="ProfileView"
                        Visibility="Collapsed"
                        Background="{DynamicResource BrushPanelBackground}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{DynamicResource ProfileTitle}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           Margin="0,0,0,20"/>

                                <TextBlock Text="{DynamicResource ProfileName}"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource BrushFieldBackground}"
                                        BorderBrush="{DynamicResource BrushFieldBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,14">
                                    <TextBox x:Name="TxtProfileFullName"
                                             BorderThickness="0"
                                             Background="Transparent"/>
                                </Border>

                                <TextBlock Text="{DynamicResource ProfileEmail}"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource BrushFieldBackground}"
                                        BorderBrush="{DynamicResource BrushFieldBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,14">
                                    <TextBox x:Name="TxtProfileEmail"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             IsReadOnly="True"/>
                                </Border>

                                <TextBlock Text="{DynamicResource ProfileRole}"
                                           Foreground="{DynamicResource BrushTextPrimary}"
                                           Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource BrushFieldBackground}"
                                        BorderBrush="{DynamicResource BrushFieldBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,18">
                                    <TextBlock x:Name="TxtProfileRole"
                                               Foreground="{DynamicResource BrushTextPrimary}"/>
                                </Border>

                                <Button Content="{DynamicResource ProfileSave}"
                                        Width="180"
                                        Height="38"
                                        Click="BtnSaveProfile_Click"/>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="{DynamicResource BrushFieldBackground}"
                                    BorderBrush="{DynamicResource BrushFieldBorder}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18"
                                    VerticalAlignment="Top">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource InterfaceSettings}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               Margin="0,0,0,18"/>

                                    <TextBlock Text="{DynamicResource LanguageLabel}"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                        <Button Content="{DynamicResource LanguageRu}"
                                                Width="70"
                                                Height="34"
                                                Margin="0,0,10,0"
                                                Click="BtnRu_Click"/>
                                        <Button Content="{DynamicResource LanguageEn}"
                                                Width="70"
                                                Height="34"
                                                Click="BtnEn_Click"/>
                                    </StackPanel>

                                    <TextBlock Text="{DynamicResource ThemeLabel}"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Margin="0,0,10,0"
                                                ToolTip="{DynamicResource LightTheme}"
                                                Click="BtnLightTheme_Click">
                                            <Image Source="/Assets/light_mode_24dp_FFFFFF.png"
                                                   Width="22"
                                                   Height="22"/>
                                        </Button>

                                        <Button Style="{StaticResource IconButtonStyle}"
                                                ToolTip="{DynamicResource DarkTheme}"
                                                Click="BtnDarkTheme_Click">
                                            <Image Source="/Assets/dark_mode_24dp_FFFFFF.png"
                                                   Width="22"
                                                   Height="22"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>