<Window x:Class="WpfApp1_lab4_5.RoomEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Номер" Height="620" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFCFC">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0" Background="#6F4E37" Padding="24,16">
            <TextBlock x:Name="TxtWindowTitle"
                       Text="Добавить номер"
                       Foreground="#FFFCFC"
                       FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- ФОРМА -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <!-- Короткое название -->
                <TextBlock Text="Короткое название" Foreground="#1A1A1A"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Height="40" Margin="0,0,0,14">
                    <TextBox x:Name="TxtShortName" BorderThickness="0"
                             Background="Transparent" Padding="12,0"
                             VerticalContentAlignment="Center" FontSize="14"/>
                </Border>

                <!-- Полное название -->
                <TextBlock Text="Полное название" Foreground="#1A1A1A"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Height="40" Margin="0,0,0,14">
                    <TextBox x:Name="TxtFullName" BorderThickness="0"
                             Background="Transparent" Padding="12,0"
                             VerticalContentAlignment="Center" FontSize="14"/>
                </Border>

                <!-- Описание -->
                <TextBlock Text="Описание" Foreground="#1A1A1A"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Margin="0,0,0,14">
                    <TextBox x:Name="TxtDescription" BorderThickness="0"
                             Background="Transparent" Padding="12,8"
                             FontSize="14" Height="80"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Border>

                <!-- Категория -->
                <TextBlock Text="Категория" Foreground="#1A1A1A"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="CmbCategory" Margin="0,0,0,14" Height="40">
                    <ComboBoxItem Content="Одноместный"/>
                    <ComboBoxItem Content="Двухместный"/>
                    <ComboBoxItem Content="Люкс"/>
                </ComboBox>

                <!-- Цена, Этаж, Площадь, Вместимость -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Цена -->
                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="Цена (руб/ночь)" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                        <Border BorderBrush="#e0e0e0" BorderThickness="1"
                                CornerRadius="6" Height="40" Margin="0,0,0,14">
                            <TextBox x:Name="TxtPrice" BorderThickness="0"
                                     Background="Transparent" Padding="12,0"
                                     VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Этаж -->
                    <StackPanel Grid.Column="2" Grid.Row="0">
                        <TextBlock Text="Этаж" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                        <Border BorderBrush="#e0e0e0" BorderThickness="1"
                                CornerRadius="6" Height="40" Margin="0,0,0,14">
                            <TextBox x:Name="TxtFloor" BorderThickness="0"
                                     Background="Transparent" Padding="12,0"
                                     VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Площадь -->
                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <TextBlock Text="Площадь (м²)" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                        <Border BorderBrush="#e0e0e0" BorderThickness="1"
                                CornerRadius="6" Height="40">
                            <TextBox x:Name="TxtArea" BorderThickness="0"
                                     Background="Transparent" Padding="12,0"
                                     VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>
                    </StackPanel>

                    <!-- Вместимость -->
                    <StackPanel Grid.Column="2" Grid.Row="1">
                        <TextBlock Text="Гостей (макс.)" Foreground="#1A1A1A" Margin="0,0,0,6"/>
                        <Border BorderBrush="#e0e0e0" BorderThickness="1"
                                CornerRadius="6" Height="40">
                            <TextBox x:Name="TxtCapacity" BorderThickness="0"
                                     Background="Transparent" Padding="12,0"
                                     VerticalContentAlignment="Center" FontSize="14"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Рейтинг -->
                <TextBlock Text="Рейтинг (0.0 - 5.0)" Foreground="#1A1A1A"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Height="40" Margin="0,0,0,14">
                    <TextBox x:Name="TxtRating" BorderThickness="0"
                             Background="Transparent" Padding="12,0"
                             VerticalContentAlignment="Center" FontSize="14"/>
                </Border>

                <!-- Удобства -->
                <TextBlock Text="Удобства (через запятую)" Foreground="#1A1A1A"
                           Margin="0,0,0,6"/>
                <Border BorderBrush="#e0e0e0" BorderThickness="1"
                        CornerRadius="6" Height="40" Margin="0,0,0,14">
                    <TextBox x:Name="TxtAmenities" BorderThickness="0"
                             Background="Transparent" Padding="12,0"
                             VerticalContentAlignment="Center" FontSize="14"/>
                </Border>

                <!-- Доступность -->
                <CheckBox x:Name="ChkAvailable"
                          Content="Номер свободен"
                          IsChecked="True"
                          Foreground="#1A1A1A"
                          FontSize="14"
                          Margin="0,0,0,8"/>

                <!-- Ошибка -->
                <TextBlock x:Name="TxtError" Foreground="Red"
                           TextWrapping="Wrap" FontSize="13"/>

            </StackPanel>
        </ScrollViewer>

        <!-- КНОПКИ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#e0e0e0" BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Height="38" Width="100"
                        Margin="0,0,10,0"
                        Background="#F5F5F0" Foreground="#1A1A1A"
                        BorderThickness="0"
                        Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnSave" Content="Сохранить"
                        Height="38" Width="120"
                        Background="#6F4E37" Foreground="#FFFCFC"
                        BorderThickness="0"
                        Click="BtnSave_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5a3e2b"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>