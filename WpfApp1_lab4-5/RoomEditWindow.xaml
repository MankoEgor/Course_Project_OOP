<Window x:Class="WpfApp1_lab4_5.RoomEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource RoomWindowTitle}"
        Height="620" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushWindowBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource BrushHeaderBackground}"
                Padding="24,16">
            <TextBlock x:Name="TxtWindowTitle"
                       Text="{DynamicResource AddRoomWindow}"
                       Foreground="{DynamicResource BrushTextOnDark}"
                       FontSize="18"
                       FontWeight="Bold"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20">

                <TextBlock Text="{DynamicResource RoomShortNameLabel}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtShortName"
                         Height="40"
                         Margin="0,0,0,14"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"/>

                <TextBlock Text="{DynamicResource RoomFullName}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtFullName"
                         Height="40"
                         Margin="0,0,0,14"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"/>

                <TextBlock Text="{DynamicResource RoomDescription}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtDescription"
                         Padding="12,8"
                         FontSize="14"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,14"/>

                <TextBlock Text="{DynamicResource RoomCategory}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>
                <ComboBox x:Name="CmbCategory"
                          Margin="0,0,0,14"
                          Height="40">
                    <ComboBoxItem Content="{DynamicResource CategorySingle}"/>
                    <ComboBoxItem Content="{DynamicResource CategoryDouble}"/>
                    <ComboBoxItem Content="{DynamicResource CategoryLux}"/>
                </ComboBox>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="{DynamicResource RoomPriceNight}"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtPrice"
                                 Height="40"
                                 Margin="0,0,0,14"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.Row="0">
                        <TextBlock Text="{DynamicResource RoomFloor}"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtFloor"
                                 Height="40"
                                 Margin="0,0,0,14"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <TextBlock Text="{DynamicResource RoomArea}"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtArea"
                                 Height="40"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Grid.Row="1">
                        <TextBlock Text="{DynamicResource RoomCapacityMax}"
                                   Foreground="{DynamicResource BrushTextPrimary}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="TxtCapacity"
                                 Height="40"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="14"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="{DynamicResource RoomRatingRange}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtRating"
                         Height="40"
                         Margin="0,0,0,14"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"/>

                <TextBlock Text="{DynamicResource RoomAmenitiesComma}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="TxtAmenities"
                         Height="40"
                         Margin="0,0,0,14"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"/>

                <CheckBox x:Name="ChkAvailable"
                          Content="{DynamicResource RoomAvailableCheckbox}"
                          IsChecked="True"
                          Foreground="{DynamicResource BrushTextPrimary}"
                          FontSize="14"
                          Margin="0,0,0,8"/>

                <TextBlock x:Name="TxtError"
                           Foreground="{DynamicResource BrushDanger}"
                           TextWrapping="Wrap"
                           FontSize="13"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource BrushPanelBackground}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Content="{DynamicResource Cancel}"
                        Height="38"
                        Width="100"
                        Margin="0,0,10,0"
                        Background="{DynamicResource BrushBadgeBackground}"
                        Foreground="{DynamicResource BrushTextPrimary}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        Click="BtnCancel_Click"/>

                <Button x:Name="BtnSave"
                        Content="{DynamicResource Save}"
                        Height="38"
                        Width="120"
                        Background="{DynamicResource BrushPrimary}"
                        Foreground="{DynamicResource BrushTextOnDark}"
                        Click="BtnSave_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>