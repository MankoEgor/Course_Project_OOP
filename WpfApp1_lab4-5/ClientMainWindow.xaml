<Window x:Class="WpfApp1_lab4_5.ClientMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ClientWindowTitle}"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="700"
        Background="{DynamicResource BrushWindowBackground}">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BrushHeaderBackground}"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource ClientWindowTitle}"
                           Foreground="{DynamicResource BrushTextOnDark}"
                           FontSize="20"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                    <Button Content="{DynamicResource LanguageRu}"
                            Width="48"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="BtnRu_Click"/>

                    <Button Content="{DynamicResource LanguageEn}"
                            Width="48"
                            Height="32"
                            Click="BtnEn_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnLogin"
                            Content="{DynamicResource Login}"
                            Width="80"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="BtnLogin_Click"/>

                    <Button x:Name="BtnRegister"
                            Content="{DynamicResource Register}"
                            Width="110"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="BtnRegister_Click"/>

                    <TextBlock x:Name="TxtUserName"
                               Foreground="{DynamicResource BrushTextOnDark}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Visibility="Collapsed"/>

                    <Button x:Name="BtnLogout"
                            Content="{DynamicResource Logout}"
                            Width="80"
                            Height="32"
                            Visibility="Collapsed"
                            Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource BrushPanelBackground}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,0,1,0"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Filters}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{DynamicResource RoomCategory}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="0,0,0,6"/>

                    <ComboBox x:Name="FilterCategory"
                        Margin="0,0,0,16"
                        SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="{DynamicResource AllCategories}" IsSelected="True"/>
                        <ComboBoxItem Content="{DynamicResource CategorySingle}"/>
                        <ComboBoxItem Content="{DynamicResource CategoryDouble}"/>
                        <ComboBoxItem Content="{DynamicResource CategoryLux}"/>
                    </ComboBox>

                    <TextBlock Text="{DynamicResource PriceUpTo}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               Margin="0,0,0,6"/>

                    <Slider x:Name="FilterPrice"
                            Minimum="0"
                            Maximum="20000"
                            Value="20000"
                            TickFrequency="1000"
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,4"
                            ValueChanged="Filter_Changed"/>

                    <TextBlock x:Name="TxtPriceFilterValue"
                               Foreground="{DynamicResource BrushPrimary}"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <CheckBox x:Name="FilterAvailable"
                              Content="{DynamicResource OnlyAvailable}"
                              Foreground="{DynamicResource BrushTextPrimary}"
                              Margin="0,0,0,20"
                              Checked="Filter_Changed"
                              Unchecked="Filter_Changed"/>

                    <Button Content="{DynamicResource ResetFilters}"
                            Height="36"
                            Click="BtnResetFilters_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1"
                  Background="{DynamicResource BrushWindowBackground}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource BrushPanelBackground}"
                        Padding="16,10"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Height="36"
                                 Padding="12,0"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>

                        <TextBlock Text="{DynamicResource SearchRoomPlaceholder}"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Margin="24,0,0,0"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   FontSize="14">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RoomsPanel" Margin="16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="260"
                                        Margin="8"
                                        Background="{DynamicResource BrushCardBackground}"
                                        BorderBrush="{DynamicResource BrushBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <Border Background="{DynamicResource BrushBadgeBackground}"
                                                Height="160"
                                                CornerRadius="10,10,0,0">
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="🏨"
                                                           FontSize="40"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Margin="14,12,14,14">
                                            <Border Background="{DynamicResource BrushBadgeBackground}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Category}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource BrushSuccess}"/>
                                            </Border>

                                            <TextBlock Text="{Binding ShortName}"
                                                       FontSize="16"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       Margin="0,0,0,4"/>

                                            <TextBlock FontSize="12"
                                                       Foreground="{DynamicResource BrushTextSecondary}"
                                                       Margin="0,0,0,6">
                                                <Run Text="{Binding Floor}"/>
                                                <Run Text=" "/>
                                                <Run Text="{DynamicResource FloorShort}"/>
                                                <Run Text=" • "/>
                                                <Run Text="{Binding Area}"/>
                                                <Run Text=" m²"/>
                                            </TextBlock>

                                            <TextBlock FontSize="13"
                                                       Foreground="{DynamicResource BrushAccent}"
                                                       Margin="0,0,0,8">
                                                <Run Text="★"/>
                                                <Run Text="{Binding Rating}"/>
                                            </TextBlock>

                                            <TextBlock FontSize="15"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource BrushPrimary}"
                                                       Margin="0,0,0,10">
                                                <Run Text="{Binding PricePerNight, StringFormat='{}{0:N0}'}"/>
                                                <Run Text=" "/>
                                                <Run Text="{DynamicResource RoomPriceSuffix}"/>
                                            </TextBlock>

                                            <TextBlock FontSize="12"
                                                       Margin="0,0,0,10">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                                <Setter Property="Text" Value="{DynamicResource AvailableDot}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource BrushSuccess}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                <Setter Property="Text" Value="{DynamicResource BusyDot}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource BrushDanger}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Button Content="{DynamicResource DetailsButton}"
                                                    Height="34"
                                                    Tag="{Binding Id}"
                                                    Click="BtnDetails_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>