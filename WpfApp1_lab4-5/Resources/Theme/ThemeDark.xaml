<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Базовые фоны -->
    <SolidColorBrush x:Key="BrushWindowBackground" Color="#1F232A"/>
    <SolidColorBrush x:Key="BrushPanelBackground" Color="#2B3038"/>
    <SolidColorBrush x:Key="BrushCardBackground" Color="#2B3038"/>
    <SolidColorBrush x:Key="BrushSidebarBackground" Color="#2F3A45"/>
    <SolidColorBrush x:Key="BrushHeaderBackground" Color="#2F3A45"/>
    <SolidColorBrush x:Key="BrushBadgeBackground" Color="#3A414B"/>

    <!-- Текст -->
    <SolidColorBrush x:Key="BrushTextPrimary" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#C9CDD3"/>
    <SolidColorBrush x:Key="BrushTextMuted" Color="#9AA3AD"/>
    <SolidColorBrush x:Key="BrushTextOnDark" Color="#FFFFFF"/>

    <!-- Поля и границы -->
    <SolidColorBrush x:Key="BrushBorder" Color="#4B5563"/>
    <SolidColorBrush x:Key="BrushFieldBackground" Color="#323842"/>
    <SolidColorBrush x:Key="BrushFieldBorder" Color="#555C66"/>

    <!-- Акценты -->
    <SolidColorBrush x:Key="BrushPrimary" Color="#5E81AC"/>
    <SolidColorBrush x:Key="BrushPrimaryHover" Color="#4C6E96"/>
    <SolidColorBrush x:Key="BrushAccent" Color="#81A1C1"/>
    <SolidColorBrush x:Key="BrushSuccess" Color="#6AA06A"/>
    <SolidColorBrush x:Key="BrushDanger" Color="#D96C6C"/>

    <!-- Совместимость со старыми ключами -->
    <SolidColorBrush x:Key="BrushBackground" Color="#1F232A"/>
    <SolidColorBrush x:Key="BrushPanel" Color="#2B3038"/>
    <SolidColorBrush x:Key="BrushText" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="BrushSubText" Color="#C9CDD3"/>
</ResourceDictionary>